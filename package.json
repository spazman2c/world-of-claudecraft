{
  "name": "world-of-claudecraft",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "author": "spazman2c",
  "type": "module",
  "main": "electron/main.cjs",
  "description": "World of Claudecraft — a WoW-Classic-style micro-MMO + headless RL training environment",
  "repository": {
    "type": "git",
    "url": "https://github.com/spazman2c/world-of-claudecraft.git"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "node scripts/electron-dev.mjs",
    "electron:pack": "npm run build && electron-builder --dir",
    "electron:build": "npm run build && electron-builder",
    "test": "vitest run",
    "build:env": "esbuild headless/env_server.ts --bundle --platform=node --format=cjs --outfile=dist-env/env_server.cjs",
    "env": "npm run build:env && node dist-env/env_server.cjs",
    "bench": "npm run build:env && node dist-env/env_server.cjs --bench",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "build:server": "esbuild server/main.ts --bundle --platform=node --format=cjs --external:pg-native --external:bufferutil --external:utf-8-validate --outfile=dist-server/server.cjs",
    "server": "npm run build:server && node dist-server/server.cjs",
    "admin:grant": "node scripts/grant_admin.mjs"
  },
  "dependencies": {
    "n8ao": "^1.10.1",
    "pg": "^8.21.0",
    "postprocessing": "^6.36.0",
    "three": "^0.165.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@gltf-transform/cli": "^4.4.0",
    "@types/node": "^25.9.2",
    "@types/pg": "^8.20.0",
    "@types/three": "^0.165.0",
    "@types/ws": "^8.18.1",
    "electron": "^42.4.0",
    "electron-builder": "^26.15.3",
    "esbuild": "^0.28.1",
    "puppeteer-core": "^25.1.0",
    "typescript": "^5.5.0",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  },
  "build": {
    "appId": "com.worldofclaudecraft.desktop",
    "productName": "World of Claudecraft",
    "icon": "build/icon.png",
    "files": [
      "dist/**",
      "electron/**",
      "build/icon.png",
      "build/icon.ico",
      "package.json"
    ],
    "directories": {
      "buildResources": "build",
      "output": "release"
    },
    "mac": {
      "category": "public.app-category.games",
      "icon": "build/icon.icns",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "category": "Game",
      "icon": "build/icon.png",
      "target": [
        "AppImage",
        "deb"
      ]
    }
  }
}
